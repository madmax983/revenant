<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Overlap_Policy__c</fullName>
    <description>Controls what happens when a new fire window is due but the previous run is still active. Skip: record a Skipped log and do not start. Allow: start a new instance regardless.</description>
    <externalId>false</externalId>
    <label>Overlap Policy</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Skip</fullName>
                <default>true</default>
                <label>Skip</label>
            </value>
            <value>
                <fullName>Allow</fullName>
                <default>false</default>
                <label>Allow</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>

<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>67.0</apiVersion>
    <description>Reference example for issue #125: the outbound half of the native-Approval-Process bridge. Fires only when Approval_Status__c changes away from Pending -- i.e. when the native Approval Process's final approval/rejection field-update action lands -- and publishes the decision NativeApprovalWorkflowExample.RequestApprovalStep is waiting on via NativeApprovalDecisionSignalInvocableAction, which JSON.serialize()s the payload in Apex so a multi-line or quote-containing approver comment can never produce invalid JSON, and hardcodes the target signal name so it can never drift out of sync with the workflow's APPROVAL_KEY constant. This action path performs no DML of its own against Workflow_Instance__c or Workflow_Step_Execution__c; it only publishes the signal the engine already knows how to consume.</description>
    <formulas>
        <name>ResolvedCorrelationKey</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Record.Correlation_Key__c}), {!$Record.Id}, {!$Record.Correlation_Key__c})</expression>
    </formulas>
    <formulas>
        <name>IsApproved</name>
        <dataType>Boolean</dataType>
        <expression>ISPICKVAL({!$Record.Approval_Status__c}, 'Approved')</expression>
    </formulas>
    <formulas>
        <name>ApproverName</name>
        <dataType>String</dataType>
        <expression>$User.FirstName &amp; ' ' &amp; $User.LastName</expression>
    </formulas>
    <actionCalls>
        <name>Signal_Decision</name>
        <label>Signal Decision</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <actionName>NativeApprovalDecisionSignalInvocableAction</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>targetKey</name>
            <value>
                <elementReference>ResolvedCorrelationKey</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>approved</name>
            <value>
                <elementReference>IsApproved</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>comments</name>
            <value>
                <elementReference>$Record.Approval_Comments__c</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>approverName</name>
            <value>
                <elementReference>ApproverName</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>idempotencyKey</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <nameSegment>NativeApprovalDecisionSignalInvocableAction</nameSegment>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </actionCalls>
    <environments>Default</environments>
    <interviewLabel>Revenant Approval Decision To Signal Example {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Revenant Approval Decision To Signal Example</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Signal_Decision</targetReference>
        </connector>
        <filterLogic>1 AND 2</filterLogic>
        <filters>
            <field>Approval_Status__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Approval_Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Pending</stringValue>
            </value>
        </filters>
        <object>Approval_Request__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
</Flow>
